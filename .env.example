# ── Speakers Platform — пример конфига ───────────────────────────────────────
# Скопируй в .env и заполни:  cp .env.example .env

# Режим: debug = полный доступ к Админке без проверки ника (локальная разработка)
#        prod  = доступ только у пользователей из ADMIN_USERNAMES
MODE=debug

# Telegram-ники администраторов через запятую (без @), только для MODE=prod
ADMIN_USERNAMES=

# ─── Хранение данных (критично для продакшена!) ───────────────────────────────
#
# ❗ По умолчанию БД лежит в <папка_проекта>/data/app.db
# На серверах (Amvera, Fly.io, Docker) папка пересоздаётся при каждом деплое
# и все данные теряются. Нужно подключить постоянный том (volume).
#
# Amvera:
#   В amvera.yml добавь volume mounted на /data, затем раскомментируй:
#   DB_PATH=/data/app.db
#   UPLOAD_FOLDER=/data/photos
#
# Fly.io:
#   fly volumes create data --size 1
#   Добавь [mounts] source="data" destination="/data" в fly.toml, затем то же.
#
# Docker:
#   docker run -v /host/data:/data ...  → то же.

# DB_PATH=/data/app.db
# UPLOAD_FOLDER=/data/photos

# PORT=5000
# CACHE_TIMEOUT=3600
